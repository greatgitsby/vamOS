From 5b6a77867cbec7807da8770dcc7258f3efe5e5f8 Mon Sep 17 00:00:00 2001
From: Robin Reckmann <robin.reckmann@gmail.com>
Date: Wed, 4 Feb 2026 00:11:38 +0900
Subject: [PATCH] Enable i2c and lsm6ds3

---
 arch/arm64/boot/dts/qcom/sdm845-comma4.dts | 25 ++++++++++++++++++++++
 arch/arm64/configs/comma4.config           |  9 ++++++++
 2 files changed, 34 insertions(+)

diff --git a/arch/arm64/boot/dts/qcom/sdm845-comma4.dts b/arch/arm64/boot/dts/qcom/sdm845-comma4.dts
index 0bd12821acd7fa..a2545349a4e901 100644
--- a/arch/arm64/boot/dts/qcom/sdm845-comma4.dts
+++ b/arch/arm64/boot/dts/qcom/sdm845-comma4.dts
@@ -344,6 +344,31 @@
 			   <GCC_LPASS_SWAY_CLK>;
 };
 
+&gpi_dma0 {
+	status = "okay";
+};
+
+&i2c4 {
+	status = "okay";
+	clock-frequency = <400000>;
+
+	lsm6ds3tr-c@6a {
+		compatible = "st,lsm6ds3tr-c";
+		reg = <0x6a>;
+
+		interrupt-parent = <&tlmm>;
+		interrupts = <84 IRQ_TYPE_EDGE_RISING>;
+
+		vdd-supply = <&vreg_l19a_3p0>;
+		vddio-supply = <&vreg_lvs1a_1p8>;
+	};
+
+};
+
+&qupv3_id_0 {
+	status = "okay";
+};
+
 &mss_pil {
 	status = "okay";
 	firmware-name = "qcom/sdm845/mba.mbn", "qcom/sdm845/modem_nm.mbn";
diff --git a/arch/arm64/configs/comma4.config b/arch/arm64/configs/comma4.config
index 4cce616114e736..7de462fef3fcb6 100644
--- a/arch/arm64/configs/comma4.config
+++ b/arch/arm64/configs/comma4.config
@@ -1,3 +1,12 @@
+#I2C
+CONFIG_I2C_QCOM_GENI=m
+
+#I2C DMA
+CONFIG_QCOM_GPI_DMA=m
+
+#SENSORS
+CONFIG_IIO_ST_LSM6DSX=m
+
 #UFS
 CONFIG_SCSI_UFS_QCOM=y
 
