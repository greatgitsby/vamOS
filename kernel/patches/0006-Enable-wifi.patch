From f769f98da5f17981ee9d57b62b56bcd1dc032752 Mon Sep 17 00:00:00 2001
From: Robin Reckmann <robin.reckmann@gmail.com>
Date: Fri, 28 Apr 2023 22:05:45 +0900
Subject: [PATCH] Enable wifi

---
 arch/arm64/boot/dts/qcom/sdm845-comma4.dts | 17 +++++++++++++++++
 1 file changed, 17 insertions(+)

diff --git a/arch/arm64/boot/dts/qcom/sdm845-comma4.dts b/arch/arm64/boot/dts/qcom/sdm845-comma4.dts
index 8f4e0ea4634780..a9c138d96a9e59 100644
--- a/arch/arm64/boot/dts/qcom/sdm845-comma4.dts
+++ b/arch/arm64/boot/dts/qcom/sdm845-comma4.dts
@@ -344,6 +344,11 @@
 			   <GCC_LPASS_SWAY_CLK>;
 };
 
+&mss_pil {
+	status = "okay";
+	firmware-name = "qcom/sdm845/mba.mbn", "qcom/sdm845/modem_nm.mbn";
+};
+
 &qupv3_id_1 {
 	status = "okay";
 };
@@ -369,3 +374,15 @@
 	vdda-phy-max-microamp = <62900>;
 	vdda-pll-max-microamp = <18300>;
 };
+
+&wifi {
+	status = "okay";
+
+	vdd-0.8-cx-mx-supply = <&vreg_l5a_0p8>;
+	vdd-1.8-xo-supply = <&vreg_l7a_1p8>;
+	vdd-1.3-rfa-supply = <&vreg_l17a_1p3>;
+	vdd-3.3-ch0-supply = <&vreg_l25a_3p3>;
+	vdd-3.3-ch1-supply = <&vreg_l23a_3p3>;
+
+	qcom,snoc-host-cap-skip-quirk;
+};
