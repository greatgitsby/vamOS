# GRAPHICS
CONFIG_BACKLIGHT_CLASS_DEVICE=y
CONFIG_DRM=y
CONFIG_DRM_DISPLAY_HELPER=y
CONFIG_DRM_MIPI_DSI=y
CONFIG_DRM_MSM=y
CONFIG_DRM_PANEL=y
CONFIG_DRM_PANEL_DWO_DO0200FAT07=y
CONFIG_DRM_PANEL_SAMSUNG_EA8074=y
CONFIG_QCOM_LLCC=y
CONFIG_QCOM_OCMEM=y

# OVERLAYFS
CONFIG_OVERLAY_FS=y

# UFS
CONFIG_PHY_QCOM_QMP=y
CONFIG_PHY_QCOM_QMP_UFS=y
CONFIG_SCSI_UFS_QCOM=y

# USB
CONFIG_PHY_QCOM_QMP_COMBO=y
CONFIG_PHY_QCOM_QMP_USB=y
CONFIG_PHY_QCOM_QUSB2=y
CONFIG_TYPEC=y
CONFIG_USB_CONFIGFS=y
CONFIG_USB_SERIAL=y
CONFIG_USB_SERIAL_WWAN=y
CONFIG_USB_SERIAL_OPTION=y

# Networking
CONFIG_IPV6=y

# WiFi
CONFIG_RFKILL=y
CONFIG_CFG80211=y
CONFIG_MAC80211=y
CONFIG_ATH10K=y
CONFIG_ATH10K_SNOC=y

# Remoteproc / Modem
CONFIG_QCOM_RMTFS_MEM=y
CONFIG_QCOM_Q6V5_MSS=y
CONFIG_QCOM_SYSMON=y
CONFIG_RPMSG_QCOM_GLINK_SMEM=y
CONFIG_QRTR=y
CONFIG_QRTR_SMD=y
CONFIG_QCOM_PDR_HELPERS=y
CONFIG_RPMSG_CHAR=y
CONFIG_RESET_QCOM_PDC=y

# PPP (for USB LTE modem data connection)
CONFIG_PPP=y
CONFIG_PPP_ASYNC=y
CONFIG_PPP_DEFLATE=y
CONFIG_PPP_BSDCOMP=y
CONFIG_PPP_MPPE=y

# I2C
CONFIG_I2C_QCOM_GENI=y

# Power monitoring (INA231)
CONFIG_SENSORS_INA2XX=y

# GPIO
# TODO: migrate gpio.sh, lte.sh, and power_drop_monitor.py to chardev (libgpiod)
# and remove GPIO_SYSFS (deprecated)
CONFIG_EXPERT=y
CONFIG_GPIO_SYSFS=y
